&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;net use Y: &lt;span class=&#34;se&#34;&gt;\\&lt;/span&gt;10.10.10.245&lt;span class=&#34;se&#34;&gt;\D&lt;/span&gt;ebian  password /user:admin
&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;net use X: &lt;span class=&#34;se&#34;&gt;\\&lt;/span&gt;10.10.10.254&lt;span class=&#34;se&#34;&gt;\P&lt;/span&gt;VE-ntfs  password /user:root
